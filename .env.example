# Douglas AI Platform — variáveis de ambiente (exemplo)
# Copie para .env.local e preencha com valores do projeto Supabase.
# Nunca commite chaves reais.

# Ambiente oficial da plataforma (público — exposto ao browser via Next.js)
# Valores permitidos: development | staging | production
# Default seguro local: development (ou omita a variável)
NEXT_PUBLIC_DOS_ENVIRONMENT=development

# Staging (projeto Supabase SEPARADO de production):
# NEXT_PUBLIC_DOS_ENVIRONMENT=staging
# NEXT_PUBLIC_SUPABASE_URL=<url-do-projeto-staging>
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-do-projeto-staging>
#
# Staging exige: mocks desligados, login real, profile ativo, audit via Edge Function.
# Configure AUDIT_INGEST_AUTH_MODE=required via Supabase secrets (não versionar).

# Supabase (público — exposto ao browser via Next.js)
# Use projetos SEPARADOS para staging e production — nunca reutilize o mesmo projeto.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
