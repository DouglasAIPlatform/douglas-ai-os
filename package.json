{
  "name": "douglas-ai-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "validate": "turbo run typecheck lint build",
    "test": "vitest run",
    "test:rbac": "vitest run --config vitest.config.ts",
    "start": "turbo start",
    "supabase:migration-plan": "node --experimental-strip-types scripts/print-supabase-migration-plan.ts",
    "release:check": "node --experimental-strip-types scripts/release-readiness.ts",
    "release:status": "node --experimental-strip-types scripts/release-status.ts",
    "release:prepare": "node --experimental-strip-types scripts/release-prepare.ts",
    "rbac:drift-check": "node --experimental-strip-types scripts/rbac-drift-check.ts",
    "staging:check": "node --experimental-strip-types scripts/staging-readiness.ts",
    "staging:bootstrap-plan": "node --experimental-strip-types scripts/staging-bootstrap-plan.ts",
    "staging:acceptance:check": "node --experimental-strip-types scripts/staging-acceptance-check.ts"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "vitest": "^3.2.4"
  }
}
