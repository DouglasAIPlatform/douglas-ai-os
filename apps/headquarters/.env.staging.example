# Douglas AI Platform — variáveis de ambiente STAGING (template)
# Copie para .env.staging.local (NUNCA commite valores reais).
#
# Regras:
# - Use um projeto Supabase DEDICADO — separado de development e production.
# - service_role NUNCA vai para o frontend ou para este arquivo versionado.
# - URL, anon key e project ref são obtidos manualmente após criar o projeto staging.
# - AUDIT_INGEST_AUTH_MODE=required é configurado via Supabase secrets (não aqui).

NEXT_PUBLIC_DOS_ENVIRONMENT=staging

# Preencha após criar o projeto Supabase de staging:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
